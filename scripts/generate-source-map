#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'USAGE'
Usage: scripts/generate-source-map [OUTPUT.md]

Generates docs/generated/source-map.md, a deterministic map of the app sources,
harness scripts, fixtures, and repository knowledge files.

Set REBOBINA_SOURCE_MAP_DATE=YYYY-MM-DD to pin the generated date for
validation diffs.
USAGE
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -gt 1 ]]; then
  usage >&2
  exit 1
fi

output="${1:-}"
generated_date="${REBOBINA_SOURCE_MAP_DATE:-$(date -u +%F)}"

emit_file_table() {
  local title="$1"
  shift

  printf '## %s\n\n' "${title}"
  printf '| Path | Lines | Purpose |\n'
  printf '| --- | ---: | --- |\n'

  local path lines purpose
  for path in "$@"; do
    [[ -f "${repo_root}/${path}" ]] || continue
    lines="$(wc -l < "${repo_root}/${path}" | tr -d ' ')"
    purpose="$(purpose_for "${path}")"
    printf '| `%s` | %s | %s |\n' "${path}" "${lines}" "${purpose}"
  done

  printf '\n'
}

purpose_for() {
  case "$1" in
    AGENTS.md) echo "Short agent entrypoint and command map." ;;
    ARCHITECTURE.md) echo "Architecture boundary, package direction, and validation loop." ;;
    README.md) echo "Project purpose, safety boundary, and current operating model." ;;
    app/src/main/AndroidManifest.xml) echo "Android TV launcher and app declaration." ;;
    app/src/main/assets/sample-catchup.json) echo "Safe local catch-up catalog fixture." ;;
    app/src/main/assets/sample-provider-metadata.json) echo "Synthetic provider-shaped metadata fixture." ;;
    app/src/main/java/com/carjorvaz/rebobina/CatchupCatalog.kt) echo "Normalized catalog models, fixture source, and JSON parser." ;;
    app/src/main/java/com/carjorvaz/rebobina/MainActivity.kt) echo "Android TV gallery UI, focus routing, and provider handoff." ;;
    app/src/main/java/com/carjorvaz/rebobina/ProviderMetadataSnapshot.kt) echo "Synthetic provider metadata source and normalizer proof." ;;
    app/src/main/java/com/carjorvaz/rebobina/ProviderRoutes.kt) echo "Provider deep-link route composition helpers." ;;
    app/src/main/res/values/strings.xml) echo "Default UI strings." ;;
    app/src/main/res/values-pt/strings.xml) echo "Portuguese UI strings." ;;
    app/src/main/res/values/styles.xml) echo "Android style declarations." ;;
    app/src/main/res/drawable/*) echo "Launcher icon and TV banner resources." ;;
    build.gradle.kts|settings.gradle.kts|app/build.gradle.kts) echo "Gradle project configuration." ;;
    flake.nix|flake.lock) echo "Nix development environment and lockfile." ;;
    scripts/build-debug) echo "Debug APK build wrapper." ;;
    scripts/check-doc-refs) echo "Local documentation reference checker." ;;
    scripts/compare-redacted-shapes) echo "Redacted metadata-shape comparison helper." ;;
    scripts/generate-source-map) echo "Generated source-map producer." ;;
    scripts/install-debug) echo "Debug APK install wrapper." ;;
    scripts/normalize-synthetic-provider-metadata) echo "Host-side synthetic metadata normalization contract." ;;
    scripts/probe-route) echo "Direct provider deep-link probe." ;;
    scripts/probe-sections) echo "Broad provider section route probe." ;;
    scripts/redact-json-shape) echo "Provider metadata shape redactor." ;;
    scripts/smoke-device) echo "Android TV smoke harness and capture workflow." ;;
    scripts/validate) echo "Fast local repository validation harness." ;;
    docs/generated/README.md) echo "Rules for generated documentation." ;;
    docs/index.md) echo "Repository knowledge-base index." ;;
    docs/QUALITY.md) echo "Quality scorecard and remaining gaps." ;;
    docs/RELIABILITY.md) echo "Reliability expectations and observation rules." ;;
    docs/SECURITY.md) echo "Provider, credential, and playback safety boundary." ;;
    docs/VALIDATION.md) echo "Validation commands and when to run them." ;;
    docs/design-docs/*) echo "Design principles and harness-engineering notes." ;;
    docs/exec-plans/active/*) echo "In-progress execution plans." ;;
    docs/exec-plans/completed/*) echo "Completed decision logs." ;;
    docs/exec-plans/tech-debt-tracker.md) echo "Known cleanup and harness work." ;;
    docs/product-specs/*) echo "Product specs, adapter boundary, and provider evidence." ;;
    docs/product-specs/provider-evidence/*) echo "Safe provider route evidence and schema." ;;
    docs/references/*) echo "Safe reference outputs and generated metadata contracts." ;;
    docs/research-notes.md) echo "Chronological research and device-observation notes." ;;
    *) echo "Repository support file." ;;
  esac
}

sorted_files_under() {
  local root="$1"
  shift

  find "${repo_root}/${root}" "$@" -type f \
    | sed "s#^${repo_root}/##" \
    | sort
}

generate() {
  cat <<HEADER
# Source Map

Generated by: \`scripts/generate-source-map\`

Source inputs: repository root files, \`app/src/main\`, \`scripts\`, and
\`docs\` knowledge files excluding this generated map.

Date generated: ${generated_date}

Manual edits: no. Regenerate with
\`REBOBINA_SOURCE_MAP_DATE=${generated_date} scripts/generate-source-map docs/generated/source-map.md\`.

This file is safe to keep in the repository. It contains paths, line counts, and
short purposes only; it must not include provider account data, raw responses,
or stream URLs.

HEADER

  local root_files=(
    "README.md"
    "AGENTS.md"
    "ARCHITECTURE.md"
    "settings.gradle.kts"
    "build.gradle.kts"
    "app/build.gradle.kts"
    "flake.nix"
  )
  emit_file_table "Root And Build Files" "${root_files[@]}"

  mapfile -t app_files < <(sorted_files_under "app/src/main")
  emit_file_table "Android App Surface" "${app_files[@]}"

  mapfile -t script_files < <(sorted_files_under "scripts")
  emit_file_table "Local Harness Scripts" "${script_files[@]}"

  mapfile -t doc_files < <(
    find "${repo_root}/docs" -type f \
      ! -path "${repo_root}/docs/generated/source-map.md" \
      | sed "s#^${repo_root}/##" \
      | sort
  )
  emit_file_table "Knowledge Base" "${doc_files[@]}"
}

trim_trailing_blank_lines() {
  python3 - "$@" <<'PY'
from pathlib import Path
import sys

if len(sys.argv) == 3:
    src = Path(sys.argv[1])
    dst = Path(sys.argv[2])
    text = src.read_text(encoding="utf-8")
    dst.write_text(text.rstrip() + "\n", encoding="utf-8")
else:
    text = sys.stdin.read()
    sys.stdout.write(text.rstrip() + "\n")
PY
}

if [[ -n "${output}" ]]; then
  tmp_output="$(mktemp)"
  generate > "${tmp_output}"
  trim_trailing_blank_lines "${tmp_output}" "${output}"
  rm -f "${tmp_output}"
else
  generate | trim_trailing_blank_lines
fi
