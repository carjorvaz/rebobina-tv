if [[ -f "${repo_root}/app/src/main/res/values-pt/strings.xml" ]]; then
  default_strings="$(
    grep -o 'name="[^"]*"' "${repo_root}/app/src/main/res/values/strings.xml" \
      | sed 's/name="//; s/"//' \
      | LC_ALL=C sort
  )"
  portuguese_strings="$(
    grep -o 'name="[^"]*"' "${repo_root}/app/src/main/res/values-pt/strings.xml" \
      | sed 's/name="//; s/"//' \
      | LC_ALL=C sort
  )"
  missing_defaults="$(comm -23 <(printf '%s\n' "${portuguese_strings}") <(printf '%s\n' "${default_strings}"))"
  missing_portuguese="$(comm -23 <(printf '%s\n' "${default_strings}") <(printf '%s\n' "${portuguese_strings}"))"
  [[ -z "${missing_defaults}" ]] || fail "Portuguese strings missing defaults: ${missing_defaults}"
  [[ -z "${missing_portuguese}" ]] || fail "Default strings missing Portuguese translations: ${missing_portuguese}"
fi

scan_for_sensitive_data() {
  local pattern="$1"
  local label="$2"
  local matches

  matches="$(
    grep -RInE \
      --exclude-dir=.git \
      --exclude-dir=.gradle \
      --exclude-dir=build \
      --exclude-dir=captures \
      --exclude='*.apk' \
      --exclude='*.aab' \
      --exclude='*.jks' \
      --exclude='*.keystore' \
      "${pattern}" \
      "${repo_root}" || true
  )"

  [[ -z "${matches}" ]] || fail "possible sensitive data (${label}): ${matches}"
}

scan_for_sensitive_data "Bearer[[:space:]]+[A-Za-z0-9._~+/=-]{20,}" "bearer token"
scan_for_sensitive_data "(access|refresh)[_-]?token[[:space:]]*[:=][[:space:]]*[\"']?[A-Za-z0-9._~+/=-]{12,}" "token assignment"
scan_for_sensitive_data "(password|passwd|cookie|session)[[:space:]]*[:=][[:space:]]*[\"']?[A-Za-z0-9._~+/=-]{12,}" "credential assignment"
scan_for_sensitive_data "https?://[^[:space:]\"']+\\.m3u8([?][^[:space:]\"']*)?" "raw stream URL"
scan_for_sensitive_data "^#EXTM3U" "playlist content"

if [[ "${run_build}" -eq 1 ]]; then
  "${repo_root}/scripts/build-debug"
fi

echo "validate: ok"
