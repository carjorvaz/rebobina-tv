  '(.schemaVersion == 1) and
   (.appPackage == "ro.digionline.tv") and
   (.scheme == "digitv") and
   (.observedDate | test("^[0-9]{4}-[0-9]{2}-[0-9]{2}$")) and
   ((.records | type) == "array" and (.records | length) > 0) and
   all(.records[];
     ((.sensitiveData == "none") or (.sensitiveData == "redacted")) and
     (.uriShape | startswith("digitv://")) and
     ((.evidence | type) == "string" and (.evidence | length) > 0))' \
  "docs/product-specs/provider-evidence/2026-05-17-digionline-tv.json"

